# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.
.DS_Store

# React Router
.react-router

# TypeScript emit files in apps (apps use bundlers, not tsc output)
# These should only exist in packages that specifically build with tsc
apps/**/*.js
apps/**/*.d.ts
apps/**/*.d.ts.map
# But keep config files
!apps/**/*.config.js
!apps/**/postcss.config.js
!apps/**/tailwind.config.js
!apps/**/eslint.config.js
!apps/**/lint-staged.config.js
# And keep drizzle generated files
!apps/**/drizzle/*.js
!apps/**/drizzle/*.d.ts
!apps/**/drizzle/*.d.ts.map

# dependencies
node_modules
.pnp
.pnp.js

# testing
coverage
apps/web/cypress/screenshots/**
apps/web/cypress/videos/**

# build
.next
build
dist
tsconfig.tsbuildinfo
build-analysis.txt

# misc
.DS_Store
*.pem
.turbo

# Logging
logs

# debug
npm-debug.log*

# local env files
.env*
!.env.example

# NX Workspaces
.nx/cache
.nx/workspace-data
**/.claude/settings.local.json
