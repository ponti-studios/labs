{
  "name": "@pontistudios/utils",
  "version": "1.0.0",
  "description": "Shared utilities for Ponti Studios labs",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "lint": "oxlint src --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.0.2",
    "zod": "^3.25.62"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "^5.8.3",
    "vitest": "^3.0.7",
    "@vitest/coverage-v8": "^3.0.7"
  },
  "peerDependencies": {
    "typescript": "^5.0.0"
  },
  "publishConfig": {
    "access": "restricted"
  }
}
