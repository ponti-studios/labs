{
  "name": "@ponti-studios/ui",
  "version": "0.1.2",
  "private": false,
  "description": "Shared UI component library for ponti-studios labs",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ponti-studios/labs.git",
    "directory": "packages/ui"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "files": [
    "dist",
    "src"
  ],
  "type": "module",
  "sideEffects": [
    "./src/styles.css",
    "./src/animations.css"
  ],
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./primitives": {
      "types": "./src/components/primitives/index.ts",
      "import": "./src/components/primitives/index.ts"
    },
    "./forms": {
      "types": "./src/components/forms/index.ts",
      "import": "./src/components/forms/index.ts"
    },
    "./feedback": {
      "types": "./src/components/feedback/index.ts",
      "import": "./src/components/feedback/index.ts"
    },
    "./overlays": {
      "types": "./src/components/overlays/index.ts",
      "import": "./src/components/overlays/index.ts"
    },
    "./navigation": {
      "types": "./src/components/navigation/index.ts",
      "import": "./src/components/navigation/index.ts"
    },
    "./data-display": {
      "types": "./src/components/data-display/index.ts",
      "import": "./src/components/data-display/index.ts"
    },
    "./layout": {
      "types": "./src/components/layout/index.ts",
      "import": "./src/components/layout/index.ts"
    },
    "./utilities": {
      "types": "./src/lib/index.ts",
      "import": "./src/lib/index.ts"
    },
    "./tokens": {
      "types": "./src/tokens/index.ts",
      "import": "./src/tokens/index.ts"
    },
    "./hooks": {
      "types": "./src/hooks/index.ts",
      "import": "./src/hooks/index.ts"
    },
    "./styles.css": "./src/styles.css",
    "./animations.css": "./src/animations.css"
  },
  "scripts": {
    "build": "vite build",
    "dev": "vite",
    "storybook": "storybook dev -p 6006",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src --fix",
    "format": "oxfmt src --write",
    "prepack": "pnpm run typecheck && pnpm run build"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@radix-ui/react-accordion": "^1.2.14",
    "@radix-ui/react-alert-dialog": "^1.1.17",
    "@radix-ui/react-avatar": "^1.2.2",
    "@radix-ui/react-dialog": "^1.1.17",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.10",
    "@radix-ui/react-popover": "^1.1.17",
    "@radix-ui/react-progress": "^1.1.10",
    "@radix-ui/react-radio-group": "^1.4.1",
    "@radix-ui/react-select": "^2.3.1",
    "@radix-ui/react-slider": "^1.4.1",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.15",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.42.0",
    "lucide-react": "^1.21.0",
    "react-day-picker": "^9.11.1",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.2.1",
    "@storybook/addon-docs": "^10.4.6",
    "@storybook/addon-links": "^10.4.6",
    "@storybook/addon-onboarding": "^10.4.6",
    "@storybook/react-vite": "^10.4.6",
    "@tailwindcss/vite": "^4.3.1",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "oxfmt": "0.56.0",
    "oxlint": "^1.71.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "storybook": "^10.4.6",
    "tailwindcss": "^4.3.1",
    "typescript": "6.0.3",
    "vite": "^8.1.0"
  },
  "peerDependencies": {
    "react": "^18.2.0 || ^19.0.0",
    "react-dom": "^18.2.0 || ^19.0.0"
  },
  "packageManager": "pnpm@10.30.3"
}
