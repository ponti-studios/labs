{
  "name": "@ponti-studios/ui",
  "version": "0.2.0",
  "private": false,
  "description": "Shared UI component library for ponti-studios labs",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ponti-studios/labs.git",
    "directory": "packages/ui"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "files": [
    "dist",
    "src",
    "THIRD_PARTY_NOTICES.md"
  ],
  "type": "module",
  "sideEffects": [
    "./src/styles.css",
    "./src/animations.css"
  ],
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./primitives": {
      "types": "./src/components/primitives/index.ts",
      "import": "./src/components/primitives/index.ts"
    },
    "./forms": {
      "types": "./src/components/forms/index.ts",
      "import": "./src/components/forms/index.ts"
    },
    "./feedback": {
      "types": "./src/components/feedback/index.ts",
      "import": "./src/components/feedback/index.ts"
    },
    "./overlays": {
      "types": "./src/components/overlays/index.ts",
      "import": "./src/components/overlays/index.ts"
    },
    "./navigation": {
      "types": "./src/components/navigation/index.ts",
      "import": "./src/components/navigation/index.ts"
    },
    "./data-display": {
      "types": "./src/components/data-display/index.ts",
      "import": "./src/components/data-display/index.ts"
    },
    "./layout": {
      "types": "./src/components/layout/index.ts",
      "import": "./src/components/layout/index.ts"
    },
    "./utilities": {
      "types": "./src/lib/index.ts",
      "import": "./src/lib/index.ts"
    },
    "./tokens": {
      "types": "./src/tokens/index.ts",
      "import": "./src/tokens/index.ts"
    },
    "./hooks": {
      "types": "./src/hooks/index.ts",
      "import": "./src/hooks/index.ts"
    },
    "./styles.css": "./src/styles.css",
    "./animations.css": "./src/animations.css"
  },
  "scripts": {
    "build": "vite build",
    "dev": "vite",
    "storybook": "storybook dev -p 6006",
    "tokens:build": "style-dictionary build --config style-dictionary.foundations.json && style-dictionary build --config style-dictionary.light.json && style-dictionary build --config style-dictionary.dark.json",
    "tokens:check": "pnpm run tokens:build && node tokens/check-foundations.mjs && git diff --exit-code -- src/tokens/generated",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src --fix",
    "format": "oxfmt src --write",
    "prepack": "pnpm run tokens:check && pnpm run typecheck && pnpm run build"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "catalog:shared",
    "lucide-react": "^1.24.0",
    "react-day-picker": "^10.0.1",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.2.1",
    "@storybook/addon-docs": "^10.5.3",
    "@storybook/addon-links": "^10.5.3",
    "@storybook/addon-onboarding": "^10.5.3",
    "@storybook/react-vite": "^10.5.3",
    "@tailwindcss/vite": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "oxfmt": "catalog:shared",
    "oxlint": "catalog:shared",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "storybook": "^10.5.3",
    "style-dictionary": "5.5.0",
    "tailwindcss": "catalog:",
    "typescript": "6.0.3",
    "vite": "catalog:"
  },
  "peerDependencies": {
    "react": "^18.2.0 || ^19.0.0",
    "react-dom": "^18.2.0 || ^19.0.0"
  },
  "packageManager": "pnpm@10.30.3"
}
