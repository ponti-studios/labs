{
  "source": ["tokens/foundations.tokens.json"],
  "platforms": {
    "css": {
      "transformGroup": "css",
      "buildPath": "src/tokens/generated/",
      "files": [{ "destination": "foundations.css", "format": "css/variables" }]
    },
    "typescript": {
      "transformGroup": "js",
      "buildPath": "src/tokens/generated/",
      "files": [{ "destination": "foundations.generated.ts", "format": "javascript/esm", "options": { "minify": true } }]
    }
  }
}
