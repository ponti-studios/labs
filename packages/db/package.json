{
  "name": "@pontistudios/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc && cp -R src/migrations dist/migrations",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "format": "oxfmt src --write",
    "load:covid": "tsx src/bin/load-covid.ts",
    "load:tfl": "tsx src/bin/load-tfl.ts",
    "db:create-schema": "tsx src/bin/create-schema.ts",
    "db:migrate": "drizzle-kit migrate",
    "db:generate": "drizzle-kit generate",
    "db:check": "drizzle-kit check",
    "clean": "rm -rf dist tsconfig.tsbuildinfo"
  },
  "dependencies": {
    "csv-parse": "6.2.1",
    "drizzle-orm": "catalog:",
    "postgres": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "drizzle-kit": "^0.31.10",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "packageManager": "pnpm@10.30.3"
}
