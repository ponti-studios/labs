{
  "name": "@pontistudios/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc && cp -R src/migrations dist/migrations",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "db:migrate": "flyway migrate",
    "db:migrate:info": "flyway info",
    "db:migrate:validate": "flyway validate",
    "db:migrate:repair": "flyway repair",
    "clean": "rm -rf dist tsconfig.tsbuildinfo"
  },
  "dependencies": {
    "kysely": "^0.28.8",
    "mysql2": "^3.6.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^24.11.0",
    "tsx": "^4.21.0",
    "typescript": "~5.7.2",
    "vitest": "^4.0.18"
  }
}
