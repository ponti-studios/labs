{
  "name": "@pontistudios/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./schema": {
      "types": "./dist/schema/index.d.ts",
      "import": "./dist/schema/index.js"
    },
    "./postgres": {
      "types": "./dist/postgres-client.d.ts",
      "import": "./dist/postgres-client.js"
    }
  },
  "scripts": {
    "build": "tsc && cp -R migrations dist/migrations",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "db:migrate": "drizzle-kit migrate",
    "db:generate": "drizzle-kit generate",
    "clean": "rm -rf dist tsconfig.tsbuildinfo"
  },
  "dependencies": {
    "drizzle-orm": "^0.44.4",
    "kysely": "^0.28.8",
    "mysql2": "^3.6.0",
    "postgres": "^3.4.7",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^24.11.0",
    "tsx": "^4.21.0",
    "typescript": "~5.7.2",
    "vitest": "^4.0.18"
  }
}
