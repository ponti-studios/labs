{
  "name": "@pontistudios/toys",
  "version": "1.9.0",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:agent": "turbo run dev --filter=@pontistudios/agent",
    "dev:agent-server": "turbo run dev --filter=@pontistudios/agent-server",
    "dev:earth": "turbo run dev --filter=@pontistudios/earth",
    "dev:dumphim": "turbo run dev --filter=dumphim",
    "dev:playground": "turbo run dev --filter=playground",
    "dev:rocco": "turbo run dev --filter=@pontistudios/rocco",
    "lint": "turbo run lint",
    "format": "turbo run format",
    "precommit": "npm run format && npm run lint",
    "prepush": "npm test",
    "prerelease": "npm test",
    "test": "turbo run test",
    "test:e2e:ci": "turbo run test:e2e:ci",
    "test:update": "turbo run test:update"
  },
  "devDependencies": {
    "@types/node": "^22.7.5",
    "oxfmt": "^0.35.0",
    "oxlint": "^0.9.7",
    "turbo": "^2.7.0",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=25"
  },
  "dependencies": {
    "@browserbasehq/stagehand": "3.1.0",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-popover": "^1.1.14",
    "@radix-ui/react-slider": "^1.3.5",
    "@testing-library/dom": "^10.4.0",
    "cmdk": "^1.1.1",
    "lefthook": "^1.7.18",
    "lucide-react": "^0.539.0",
    "mysql2": "^3.6.0",
    "vite-plugin-static-copy": "3.2.0",
    "workbox-build": "^7.0.0",
    "workbox-window": "^7.1.0"
  },
  "packageManager": "npm@10.9.2",
  "overrides": {
    "esbuild": "^0.27.3",
    "zod": "^4.2.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
