{
  "name": "@pontistudios/labs",
  "version": "1.11.0",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:earth": "turbo run dev --filter=@pontistudios/earth",
    "dev:commune": "turbo run dev --filter=@pontistudios/commune",
    "dev:labyrinth": "turbo run dev --filter=@pontistudios/labyrinth",
    "dev:ui": "turbo run storybook --filter=@ponti-studios/ui",
    "dev:health": "turbo run dev --filter=@pontistudios/health",
    "lint": "turbo run lint",
    "format": "turbo run format",
    "knip": "knip",
    "duplicates": "jscpd --threshold 10 --config .jscpd.jsonc",
    "dedupe": "pnpm dedupe 2>&1 || echo 'Run pnpm install after fixing conflicts'",
    "precommit": "pnpm run format && pnpm run lint",
    "prepush": "pnpm test",
    "prerelease": "pnpm test",
    "test": "turbo run test",
    "test:e2e:ci": "turbo run test:e2e:ci",
    "test:update": "turbo run test:update",
    "typecheck": "turbo run typecheck",
    "ui:storybook": "pnpm --filter @ponti-studios/ui storybook"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "jscpd": "^5.0.12",
    "knip": "^6.27.0",
    "oxfmt": "catalog:shared",
    "oxlint": "catalog:shared",
    "turbo": "^2.10.5",
    "typescript": "catalog:"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "pnpm@10.30.3"
}
