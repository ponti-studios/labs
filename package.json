{
  "name": "@pontistudios/toys",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:earth": "turbo run dev --filter=@pontistudios/earth",
    "dev:dumphim": "turbo run dev --filter=dumphim",
    "dev:playground": "turbo run dev --filter=playground",
    "dev:rocco": "turbo run dev --filter=@pontistudios/rocco",
    "earth:tiles:imagery": "pnpm --filter @pontistudios/earth tiles:imagery",
    "earth:tiles:terrain": "pnpm --filter @pontistudios/earth tiles:terrain",
    "lint": "turbo run lint",
    "format": "turbo run format",
    "knip": "knip",
    "duplicates": "jscpd --threshold 10 --config .jscpd.jsonc",
    "dedupe": "pnpm dedupe 2>&1 || echo 'Run pnpm install after fixing conflicts'",
    "precommit": "pnpm run format && pnpm run lint",
    "prepush": "pnpm test",
    "prerelease": "pnpm test",
    "test": "turbo run test",
    "test:e2e:ci": "turbo run test:e2e:ci",
    "test:update": "turbo run test:update"
  },
  "dependencies": {
    "@browserbasehq/stagehand": "3.1.0",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-popover": "^1.1.14",
    "@radix-ui/react-slider": "^1.3.5",
    "@testing-library/dom": "^10.4.0",
    "cmdk": "^1.1.1",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^0.539.0",
    "mysql2": "^3.6.0",
    "postgres": "^3.4.9",
    "vite-plugin-static-copy": "3.2.0",
    "workbox-build": "^7.0.0",
    "workbox-window": "^7.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.7.5",
    "jscpd": "^4.0.8",
    "knip": "^5.47.0",
    "oxfmt": "^0.35.0",
    "oxlint": "^0.9.7",
    "rolldown": "^1.0.0-rc.9",
    "turbo": "^2.7.0",
    "typescript": "^5.6.3"
  },
  "overrides": {
    "esbuild": "^0.27.3",
    "zod": "^4.2.0"
  },
  "engines": {
    "node": "24.11.0"
  },
  "packageManager": "pnpm@10.30.3"
}
