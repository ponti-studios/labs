{
  "name": "@pontistudios/labs",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:earth": "turbo run dev --filter=@pontistudios/earth",
    "dev:commune": "turbo run dev --filter=@pontistudios/commune",
    "dev:labyrinth": "turbo run dev --filter=@pontistudios/labyrinth",
    "dev:ui": "turbo run storybook --filter=@pontistudios/ui",
    "dev:health": "turbo run dev --filter=@pontistudios/health",
    "lint": "turbo run lint",
    "format": "turbo run format",
    "knip": "knip",
    "duplicates": "jscpd --threshold 10 --config .jscpd.jsonc",
    "dedupe": "pnpm dedupe 2>&1 || echo 'Run pnpm install after fixing conflicts'",
    "precommit": "pnpm run format && pnpm run lint",
    "prepush": "pnpm test",
    "prerelease": "pnpm test",
    "test": "turbo run test",
    "test:e2e:ci": "turbo run test:e2e:ci",
    "test:update": "turbo run test:update",
    "typecheck": "turbo run typecheck",
    "ui:storybook": "pnpm --filter @pontistudios/ui storybook"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "jscpd": "^4.2.3",
    "knip": "^6.6.1",
    "oxfmt": "0.53.0",
    "oxlint": "^1.66.0",
    "pm2": "^7.0.1",
    "rolldown": "1.0.0-rc.17",
    "turbo": "^2.9.6",
    "typescript": "catalog:"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "pnpm@10.30.3",
  "pnpm": {
    "overrides": {
      "esbuild": "^0.27.3",
      "zod": "^4.2.0",
      "lodash": ">=4.17.23",
      "tmp": ">=0.2.4",
      "ip-address": ">=10.1.1",
      "icu-minify": ">=4.9.2",
      "next-intl": ">=4.9.2",
      "basic-ftp": ">=5.3.1",
      "fast-uri": ">=3.1.1",
      "@protobufjs/utf8": ">=1.1.1",
      "protobufjs": ">=7.5.6",
      "systeminformation": ">=5.31.6",
      "next": ">=16.2.5",
      "kysely": ">=0.28.17"
    }
  }
}
