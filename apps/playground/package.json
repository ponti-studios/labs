{
	"name": "playground",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"scripts": {
		"build": "react-router build",
		"dev": "react-router dev",
		"lint": "oxlint app --fix",
		"format": "oxfmt app --write",
