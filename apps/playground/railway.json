{
	"$schema": "https://railway.app/railway.schema.json",
	"build": {
		"builder": "RAILPACK",
		"buildCommand": "npm ci && npm run build --workspace=playground"
	},
	"deploy": {
		"startCommand": "cd apps/playground && npm start",
		"healthcheckPath": "/",
		"healthcheckTimeout": 300,
		"restartPolicyType": "ON_FAILURE"
	}
}
