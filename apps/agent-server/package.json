{
  "name": "@pontistudios/agent-server",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx --env-file ../../.env --watch src/index.ts",
    "build": "tsc && cp -r src/*.js dist/",
    "start": "node --env-file ../../.env dist/index.js",
    "lint": "oxlint src --fix",
    "format": "oxfmt src --write"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "hono": "^4.7.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  }
}
