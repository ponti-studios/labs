{
	"$schema": "https://railway.app/railway.schema.json",
	"build": {
		"builder": "RAILPACK",
		"buildCommand": "npm ci && npm run build --workspace=@pontistudios/medico"
	},
	"deploy": {
		"startCommand": "cd apps/medico && npm start",
		"healthcheckPath": "/",
		"healthcheckTimeout": 300,
		"restartPolicyType": "ON_FAILURE",
		"numReplicas": 1
	}
}
