{
  "entities": {
    "Thought": {
      "title": "Thought",
      "description": "A single fragment of chat state stored in browser localStorage",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["text", "voice", "image", "link", "suggestion"] },
        "content": { "type": "string" },
        "timestamp": { "type": "number" },
        "metadata": { "type": "object" }
      },
      "required": ["type", "content", "timestamp"]
    }
  },
  "storage": {
    "local": {
      "key": "nexus-thoughts",
      "description": "Browser localStorage used for conversation history"
    }
  }
}
