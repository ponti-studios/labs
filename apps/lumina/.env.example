# VITE_OLLAMA_BASE_URL: Ollama server URL.
# Defaults to http://localhost:11434.
VITE_OLLAMA_BASE_URL="http://localhost:11434"

# VITE_OLLAMA_CHAT_MODEL: Text chat model used for general conversation.
VITE_OLLAMA_CHAT_MODEL="llama3.1"

# VITE_OLLAMA_VISION_MODEL: Vision-capable model used for image analysis.
VITE_OLLAMA_VISION_MODEL="llama3.2-vision"

# VITE_OLLAMA_INTENT_MODEL: Model used for quick intent detection.
VITE_OLLAMA_INTENT_MODEL="llama3.1"

# VITE_OLLAMA_TRANSCRIBE_MODEL: Optional transcription model for audio input.
# Leave blank if you do not have an Ollama-compatible transcription model installed.
VITE_OLLAMA_TRANSCRIBE_MODEL=""

# VITE_OLLAMA_TTS_MODEL: Optional text-to-speech model.
# Leave blank to use the browser speech-synthesis fallback.
VITE_OLLAMA_TTS_MODEL=""

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
