{
  "name": "@pontistudios/home",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "next build",
    "build:sitemap": "next-sitemap --config next-sitemap.config.js",
    "commit": "cz",
    "dev": "next dev --turbo",
    "format": "pnpm exec oxfmt --write app components",
    "lint": "run-p run-lint run-stylelint",
    "preview": "npm run build && npm start",
    "preview:test": "start-server-and-test preview http://localhost:4173",
    "preview:next": "npx next dev -p 4173",
    "refresh-deps": "rm package-lock.json && rm -rf node_modules && npm install",
    "run-lint": "pnpm exec oxlint app components --fix",
    "run-stylelint": "stylelint --cache --fix --ignore-path .gitignore app/**/*.css",
    "start": "next start",
    "test": "vitest --run",
    "test:coverage": "open coverage/jest/lcov-report/index.html ",
    "test:e2e:ci": "next build && npm run preview:test 'npx playwright test'",
    "test:e2e": "npm run preview:test 'npx playwright test'",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit --incremental false",
    "validate": "run-p lint test test:e2e:ci"
  },
  "dependencies": {
    "@pontistudios/db": "workspace:*",
    "@pontistudios/ui": "workspace:*",
    "@pontistudios/utils": "workspace:*",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-popover": "^1.1.14",
    "@radix-ui/react-slot": "^1.1.2",
    "@tailwindcss/forms": "^0.5.7",
    "@tanstack/react-query": "^5.13.4",
    "@tanstack/react-query-devtools": "^5.13.5",
    "@tanstack/react-query-next-experimental": "^5.13.4",
    "class-variance-authority": "^0.7.1",
    "classnames": "^2.5.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "framer-motion": "^12.4.7",
    "lucide-react": "^0.414.0",
    "next": "^15.3.3",
    "next-intl": "^4.8.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-icons": "^4.12.0",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@commitlint/cli": "^18.4.4",
    "@commitlint/config-conventional": "^18.4.4",
    "@playwright/test": "^1.40.1",
    "@tailwindcss/postcss": "^4.1.10",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/css-mediaquery": "^0.1.4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/styled-components": "^5.1.34",
    "@types/xml2js": "^0.4.14",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/coverage-v8": "^3.0.7",
    "autoprefixer": "^10.4.16",
    "babel-plugin-react-compiler": "^19.1.0-rc.2",
    "c8": "^8.0.1",
    "commitizen": "^4.3.0",
    "css-mediaquery": "^0.1.2",
    "cssnano": "^6.1.2",
    "cz-conventional-changelog": "^3.3.0",
    "dotenv": "^16.5.0",
    "jsdom": "^24.0.0",
    "lint-staged": "^15.2.0",
    "msw": "^2.0.11",
    "next-router-mock": "^0.9.11",
    "next-sitemap": "^4.2.3",
    "npm-run-all": "^4.1.5",
    "oxfmt": "^0.35.0",
    "oxlint": "^0.9.7",
    "postcss": "^8.4.32",
    "psl": "^1.9.0",
    "rollup-plugin-analyzer": "^4.0.0",
    "start-server-and-test": "^2.0.3",
    "styled-components": "^6.1.2",
    "stylelint": "^16.3.1",
    "stylelint-config-recommended": "^14.0.0",
    "stylelint-config-standard": "^36.0.0",
    "tailwind-merge": "^2.6.0",
    "tailwindcss": "^4.1.10",
    "tsx": "^4.20.3",
    "typescript": "^5.2.2",
    "url-parse": "^1.5.3",
    "vite": "^5.0.10",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.0.7",
    "whatwg-fetch": "^3.6.20"
  },
  "lint-staged": {
    "**/*.{js,jsx,ts,tsx}": [
      "pnpm exec oxlint --fix",
      "pnpm exec oxfmt --write"
    ],
    "**/*.{json,css,scss,md}": [
      "pnpm exec oxfmt --write"
    ]
  },
  "packageManager": "pnpm@10.30.3"
}
