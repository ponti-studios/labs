{
	"compilerOptions": {
		"target": "ES2022",
		"lib": ["dom", "dom.iterable", "esnext"],
		"allowJs": true,
		"skipLibCheck": true,
		"strict": true,
		"noEmit": true,
		"esModuleInterop": true,
		"module": "esnext",
		"moduleResolution": "bundler",
		"resolveJsonModule": true,
		"isolatedModules": true,
		"jsx": "react-jsx",
		"incremental": true,
		"plugins": [
			{
				"name": "react-router"
			}
		],
		"paths": {
			"@/*": ["./src/*"],
			"~/*": ["./app/*"]
		}
	},
	"include": [
		"**/*.ts",
		"**/*.tsx",
		".react-router/types/**/*.ts",
		"react-router.config.ts",
		"vite.config.ts"
	],
	"exclude": ["node_modules"]
}
