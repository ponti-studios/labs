{
	"name": "@pontistudios/case-study-symptoms",
	"private": true,
	"type": "module",
	"version": "0.1.0",
	"scripts": {
		"build": "react-router build",
		"dev": "react-router dev",
		"start": "react-router-serve ./build/server/index.js --port=${PORT:-3000}",
		"lint": "oxlint app --fix",
		"format": "oxfmt app --write",
