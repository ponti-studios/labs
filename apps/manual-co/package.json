		"autoprefixer": "^10.4.16",
		"jsdom": "^26.0.0",
		"postcss": "^8.4.31",
		"tailwindcss": "^4.1.10",
		"tsx": "^4.20.3",
		"typescript": "^5.6.3",
		"vite": "^6.3.3",
		"vite-tsconfig-paths": "^5.1.4",
		"vitest": "^3.0.9"
	},
	"packageManager": "npm@10.9.2"
