		"@tanstack/react-query": "^5.0.0",
		"@tanstack/react-query-devtools": "^5.0.0",
		"clsx": "^2.1.1",
		"daisyui": "^5.0.9",
		"date-fns": "^4.1.0",
		"isbot": "^5.1.27",
		"react": "^19.1.0",
		"react-dom": "^19.1.0",
		"react-router": "^7.5.3",
		"sonner": "^2.0.1",
		"tailwind-merge": "^2.6.0",
		"zod": "^3.24.2"
	},
	"devDependencies": {
		"@playwright/test": "^1.51.1",
		"@react-router/dev": "^7.5.3",
