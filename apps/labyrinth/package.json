{
  "name": "@pontistudios/labyrinth",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "react-router build",
    "dev": "react-router dev",
    "lint": "oxlint app --fix",
    "format": "oxfmt app --write",
    "realitea:generate-scheduled": "tsx --tsconfig tsconfig.json scripts/generate-realitea-scheduled-puzzle.ts",
    "realitea:generate-reserve": "tsx --tsconfig tsconfig.json scripts/generate-realitea-reserve-puzzles.ts",
    "realitea:promote-current-window": "tsx --tsconfig tsconfig.json scripts/promote-realitea-current-window.ts",
    "realitea:reconcile-inventory": "tsx --tsconfig tsconfig.json scripts/reconcile-realitea-inventory.ts",
    "start": "react-router-serve ./build/server/index.js --port=${PORT:-3000}",
    "test": "vitest run --environment jsdom --coverage --reporter verbose --passWithNoTests",
    "typecheck": "react-router typegen && tsc"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1058.0",
    "@emotion/styled": "^11.14.1",
    "@pontistudios/ai": "workspace:*",
    "@pontistudios/db": "workspace:*",
    "@pontistudios/ui": "workspace:*",
    "@preact/signals-react": "^3.10.0",
    "@react-router/node": "catalog:",
    "@react-router/serve": "catalog:",
    "@tanstack/react-query": "catalog:",
    "@testing-library/jest-dom": "catalog:",
    "@types/three": "^0.184.1",
    "class-variance-authority": "^0.7.1",
    "dotenv": "^17.4.2",
    "framer-motion": "^12.40.0",
    "isbot": "^5.1.40",
    "iso-3166-1": "^2.1.1",
    "lucide-react": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-router": "catalog:",
    "recharts": "^3.8.1",
    "three": "^0.184.0",
    "vitest": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@pontistudios/tsconfig": "workspace:*",
    "@react-router/dev": "catalog:",
    "@tailwindcss/vite": "catalog:",
    "@testing-library/dom": "catalog:",
    "@testing-library/react": "catalog:",
    "@testing-library/user-event": "^14.6.1",
    "@types/google.maps": "^3.65.0",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@types/react-router-dom": "^5.3.3",
    "@vitest/coverage-v8": "catalog:",
    "jsdom": "catalog:",
    "tailwindcss": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vite-tsconfig-paths": "catalog:"
  },
  "packageManager": "pnpm@10.30.3"
}
