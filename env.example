# Database Configuration
# Clone and run foundation (ghcr.io/ponti-studios/hominem/postgres) first:
#   git clone https://github.com/ponti-studios/foundation.git ../foundation
#   cd ../foundation && just docker-up
DATABASE_URL=postgresql://postgres:postgres@localhost:5434/labs
TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:4433/labs-test

# Redis Configuration
REDIS_URL=redis://localhost:6379

# Application Configuration
NODE_ENV=development

# Logging Configuration
LOG_LEVEL=info
ENABLE_REQUEST_LOGGING=true

# External Logging Services (Optional)
# Only used in production - PostHog is disabled in development
POSTHOG_API_KEY=your_posthog_api_key_here
POSTHOG_HOST=https://app.posthog.com
# DATADOG_CLIENT_TOKEN=your_datadog_token_here
# DATADOG_SITE=datadoghq.com
# AWS_REGION=us-east-1
# LOGROCKET_APP_ID=your_logrocket_app_id_here
