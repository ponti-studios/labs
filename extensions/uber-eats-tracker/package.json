{
	"name": "@pontistudios/uber-eats-extension",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"scripts": {
		"dev": "npm-run-all --parallel dev:vite watch:build",
		"dev:vite": "vite",
		"watch:build": "tsc -b --watch && vite build --watch",
		"build": "tsc -b && vite build",
		"lint": "oxlint src --fix",
		"format": "oxfmt src --write",
		"preview": "vite preview"
	},
	"dependencies": {
		"@tailwindcss/cli": "^4.0.13",
		"@tailwindcss/vite": "^4.0.13",
		"daisyui": "^5.0.3",
		"react": "^18.3.1",
		"react-dom": "^18.3.1",
		"tailwindcss": "^4.0.13"
	},
	"devDependencies": {
		"@types/chrome": "^0.0.309",
		"@types/react": "^18.3.3",
		"@types/react-dom": "^18.3.0",
		"@vitejs/plugin-react": "^4.3.1",
		"npm-run-all": "^4.1.5",
		"typescript": "^5.2.2",
		"vite": "8.0.0-beta.18",
		"vite-plugin-static-copy": "^1.0.6"
	}
}
