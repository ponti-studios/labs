{
  "uid": "tasks_overview",
  "title": "Tasks — Overview",
  "schemaVersion": 36,
  "version": 1,
  "refresh": "30s",
  "panels": [
    {
      "type": "stat",
      "title": "Total tasks",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 3 },
      "datasource": { "type": "prometheus", "uid": "PAF133A725F0C4CBF" },
      "fieldConfig": { "defaults": { "calcs": ["lastNotNull"] }, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "PAF133A725F0C4CBF" },
          "expr": "sum(tasks_total_count)",
          "refId": "A",
          "format": "time_series"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Open tasks",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 3 },
      "datasource": { "type": "prometheus", "uid": "PAF133A725F0C4CBF" },
      "fieldConfig": { "defaults": { "calcs": ["lastNotNull"] }, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "PAF133A725F0C4CBF" },
          "expr": "sum(tasks_open_count)",
          "refId": "A",
          "format": "time_series"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Tasks due (next 7d trend)",
      "gridPos": { "x": 0, "y": 3, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "PAF133A725F0C4CBF" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "PAF133A725F0C4CBF" },
          "expr": "sum(tasks_due_7d)",
          "refId": "A",
          "format": "time_series"
        }
      ]
    },
    {
      "type": "stat",
      "title": "SQLite total (direct)",
      "gridPos": { "x": 6, "y": 11, "w": 6, "h": 3 },
      "datasource": { "type": "simpod-sqlite-datasource", "uid": "P38F665EDBE4B4B17" },
      "fieldConfig": { "defaults": { "calcs": ["lastNotNull"] }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT total_tasks AS cnt FROM tasks_overview_summary;"
        }
      ]

    }
  ],
  "time": { "from": "now-12w", "to": "now" }
}
